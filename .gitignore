venv/

# data (local DB, never commit transcripts/usage)
data/*.db
data/*.db-shm
data/*.db-wal
data/*.sqlite*
# raw archive 원문 — 로컬 전용, 커밋하지 않음. 인라인 주석은 gitignore에서 패턴의 일부로 해석되므로 반드시 별도 줄로 둘 것.
data/archive/

# env / secrets
.env
*.local.json

# personal config (budget) — never commit
config/tokenomy.config.json

# OS
.DS_Store
Thumbs.db

