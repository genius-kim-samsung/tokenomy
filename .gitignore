.ruff_cache/

# PyInstaller 빌드 산출물
build/
dist/

# venv
.venv/
venv/

# data — 로컬 전용 데이터 디렉토리 전체. 절대 커밋 금지.
# DB(토큰 메타 + 첫 프롬프트 발췌)·raw 아카이브 원문·중첩 산출물이 모두 여기 쌓인다.
# 디렉토리째 무시해야 *.db 패턴에 안 걸리는 백업(.bak-*)·중첩 폴더까지 새지 않는다.
data/
# 루트 stray DB 가드 — 앱 정상 DB는 data/에만 쓴다. repo 루트에서 sqlite를 연
# 흔적(0바이트 빈 파일 등)이 추적 후보로 새는 것을 막는다(프라이버시 경계).
/*.db

# env / secrets
.env
*.local.json

# 공식 사용량 실측 원문·로컬 fixture(가짜 아님) — 커밋 금지(커밋 정본은 tests/fixtures/official/*.json)
tests/fixtures/official/local/

# personal config (budget) — never commit
config/tokenomy.config.json

# OS
.DS_Store
Thumbs.db

# tool-local (Claude Code / gstack — worktrees·settings 로컬 전용)
.gstack/
.claude/*
# 단, 프로젝트 스킬은 추적해 머신 간(사내 PC↔집 데스크탑) 공유한다.
# (.claude/는 디렉토리 자체를 ignore하면 하위를 되살릴 수 없어 .claude/* + negation 사용)
!.claude/skills/

# 설계 메모(docs/) — 로컬 전용으로 전환(2026-06-21). 추적 제외, 디스크엔 보존.
docs/

# Tailwind standalone 바이너리 — dev 도구, 커밋 안 함(산출 app.css만 추적)
tools/

# 로컬 전용 디자인 분석 문서(공개 제외)
/DESIGN.md

# 세션 로컬 스크래치(codex 세션 id 등) — 커밋 금지
.context/

# subagent-driven-development 진행 스크래치(브리프·리포트·diff·원장) — 커밋 금지
